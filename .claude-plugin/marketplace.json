{
  "name": "dominikwozniak-skills",
  "owner": {
    "name": "Dominik Wozniak"
  },
  "metadata": {
    "description": "An opinionated Claude Code starter kit. Workflow loop, configurable git skill, guardrails, autoloop quality hooks, handoff, and an optional pre-commit setup.",
    "version": "0.1.0"
  },
  "plugins": [
    {
      "name": "bootstrap-workflow",
      "version": "0.1.0",
      "source": "./plugins/bootstrap-workflow",
      "keywords": ["bootstrap", "setup", "templates", "scaffolding"],
      "category": "utilities",
      "tags": ["workflow", "automation"]
    },
    {
      "name": "git-workflow",
      "version": "0.1.0",
      "source": "./plugins/git-workflow",
      "keywords": ["git", "commit", "pull-request", "branch", "conventions"],
      "category": "utilities",
      "tags": ["workflow", "version-control"]
    },
    {
      "name": "session-handoff",
      "version": "0.1.0",
      "source": "./plugins/session-handoff",
      "keywords": ["handoff", "session", "context", "continuation"],
      "category": "productivity",
      "tags": ["context-management", "workflow"]
    },
    {
      "name": "setup-pre-commit",
      "version": "0.1.0",
      "source": "./plugins/setup-pre-commit",
      "keywords": ["husky", "lint-staged", "prettier", "pre-commit"],
      "category": "utilities",
      "tags": ["quality", "hooks", "linting", "automation"]
    }
  ]
}
