{
  "name": "claude-kit",
  "version": "0.3.0",
  "private": true,
  "description": "An opinionated Claude Code starter kit.",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "lint": "agnix .",
    "lint:fix": "agnix --fix .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "validate:manifests": "scripts/validate-manifests.sh"
  },
  "devDependencies": {
    "agnix": "^0.22.0",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "agnix"
    ]
  }
}
